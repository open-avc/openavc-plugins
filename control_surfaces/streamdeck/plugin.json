{
    "id": "streamdeck",
    "name": "Elgato Stream Deck",
    "version": "1.0.0",
    "author": "OpenAVC",
    "description": "Use Elgato Stream Deck hardware as a physical control surface.",
    "category": "control_surface",
    "license": "MIT",
    "platforms": ["win_x64", "linux_x64", "linux_arm64"],
